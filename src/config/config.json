{
  "site": {
    "title": "mynutrihome",
    "base_url": "https://nutrition-demo.netlify.app",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/pink.png",
    "logo": "/images/pink.png",
    "logo_darkmode": "/images/pink.png",
    "logo_width": "58",
    "logo_height": "62",
    "logo_text": "mynutrihome"
  },

  "settings": {
    "search": true,
    "sticky_header": true,
    "theme_switcher": false,
    "default_theme": "light",
    "pagination": 2,
