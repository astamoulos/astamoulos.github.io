  },

  "navigation_button": {
    "enable": true,
    "label": "Κλείσε Ραντεβού",
    "link": "/contact"
  },

  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },

  "disqus": {
    "enable": false,
    "shortname": "themefisher-template",
    "settings": {}
  },

  "metadata": {
    "meta_author": "mynutrihome",
    "meta_image": "/images/og-image.png",
    "meta_description": "Ολιστική διατροφική καθοδήγηση για απώλεια βάρους, αθλητική απόδοση και κλινική υποστήριξη."
